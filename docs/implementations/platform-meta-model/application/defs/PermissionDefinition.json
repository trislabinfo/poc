{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datarizen.io/schemas/platform-meta-model/defs/PermissionDefinition.json",
  "$defs": {
    "PermissionDefinition": {
      "type": "object",
      "description": "Permission definition; defined only inside application definition.",
      "required": ["resourceType", "resourceId", "actions"],
      "properties": {
        "resourceType": { "type": "string", "enum": ["Entity", "Page", "Workflow"] },
        "resourceId": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string", "enum": ["create", "read", "update", "delete", "execute"] }
        },
        "tenantScoped": { "type": "boolean", "default": false }
      }
    }
  }
}
