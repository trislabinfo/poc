{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "tenant-route": { "ClusterId": "tenant", "Match": { "Path": "/api/tenant/{**catch-all}" } },
      "identity-route": { "ClusterId": "identity", "Match": { "Path": "/api/identity/{**catch-all}" } },
      "user-route": { "ClusterId": "runtime", "Match": { "Path": "/api/user/{**catch-all}" } },
      "runtime-route": { "ClusterId": "runtime", "Match": { "Path": "/api/runtime/{**catch-all}" } },
      "feature-route": { "ClusterId": "appbuilder", "Match": { "Path": "/api/feature/{**catch-all}" } },
      "appbuilder-route": { "ClusterId": "appbuilder", "Match": { "Path": "/api/appbuilder/{**catch-all}" } },
      "tenantapplication-route": { "ClusterId": "tenantapplication", "Match": { "Path": "/api/tenantapplication/{**catch-all}" } },
      "health-route": { "ClusterId": "runtime", "Match": { "Path": "/health" } }
    },
    "Clusters": {
      "tenant": { "HttpRequest": { "ActivityTimeout": "00:03:00" }, "Destinations": { "destination1": { "Address": "http://controlpanel" } } },
      "identity": { "Destinations": { "destination1": { "Address": "http://controlpanel" } } },
      "controlpanel": { "Destinations": { "destination1": { "Address": "http://controlpanel" } } },
      "runtime": { "Destinations": { "destination1": { "Address": "http://runtime" } } },
      "appbuilder": { "Destinations": { "destination1": { "Address": "http://appbuilder" } } },
      "tenantapplication": { "Destinations": { "destination1": { "Address": "http://controlpanel" } } }
    }
  }
}
